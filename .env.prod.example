# Production Environment Configuration for NiftyTools

# Application Versions (use specific tags in production)
BACKEND_VERSION=main-latest
USER_FRONTEND_VERSION=main-latest
ADMIN_FRONTEND_VERSION=main-latest

# Domain Configuration (for CloudPanel nginx setup)
USER_DOMAIN=niftytools.com
ADMIN_DOMAIN=admin.niftytools.com

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_32_chars_minimum_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_32_chars_minimum_here

# S3 Storage Configuration
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=niftytools-production
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# Optional: Custom Registry (if using private registry)
# REGISTRY=your-registry.com/niftytools