{
  "name": "@niftytools/backend",
  "version": "1.0.0",
  "description": "NiftyTools backend API server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist",
    "db:migrate": "bun src/database/migrate.ts",
    "db:seed": "bun src/database/seed.ts",
    "db:reset": "bun src/database/reset.ts",
    "health-check": "curl -f http://localhost:3000/health || exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.4.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "uuid": "^10.0.0",
    "@niftytools/shared": "workspace:*",
    "@niftytools/text-tools-plugin": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "vitest": "^3.2.4"
  }
}