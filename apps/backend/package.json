{
  "name": "@niftytools/backend",
  "version": "1.1.0",
  "description": "NiftyTools backend API server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist",
    "db:migrate": "node dist/database/migrate.js",
    "db:seed": "node dist/database/seed.js",
    "db:reset": "node dist/database/reset.js",
    "health-check": "curl -f http://localhost:3000/health || exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "@niftytools/shared": "file:../../packages/shared",
    "@niftytools/text-tools-plugin": "file:../../plugins/text-tools"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "vitest": "^3.2.4"
  }
}