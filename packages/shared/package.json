{
  "name": "@niftytools/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, utilities, and interfaces for NiftyTools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^24.1.0"
  },
  "dependencies": {
    "fastify": "^5.4.0"
  }
}